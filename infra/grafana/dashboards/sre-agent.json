  "panels": [
    {
      "type": "stat",
      "title": "Scrape targets up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(up)", "legendFormat": "up", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" }
    },
    {
      "type": "stat",
      "title": "Active incidents",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(sre_agent_active_incidents) or vector(0)", "legendFormat": "incidents", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "LLM tokens (last hour)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(sre_agent_llm_tokens_used_total[1h])) or vector(0)", "legendFormat": "tokens", "refId": "A" }
      ],
      "options": { "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "Tool calls (last hour)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(sre_agent_tool_invocations_total[1h])) or vector(0)", "legendFormat": "calls", "refId": "A" }
      ],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "type": "timeseries",
      "title": "LLM tokens / sec by kind",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (kind) (rate(sre_agent_llm_tokens_used_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 },
          "unit": "short"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Tool invocations / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool, status) (rate(sre_agent_tool_invocations_total[5m]))",
          "legendFormat": "{{tool}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 60 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP requests / sec to agent",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{job=\"agent\"}[5m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Agent process memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"agent\"}",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "type": "heatmap",
      "title": "RCA confidence distribution",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (le) (increase(sre_agent_rca_confidence_bucket[15m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": { "calculate": false, "yAxis": { "unit": "short", "min": "0", "max": "1" } }
    },
    {
      "type": "timeseries",
      "title": "HIL approval latency (p50/p95/p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(sre_agent_hil_approval_latency_seconds_bucket[10m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sre_agent_hil_approval_latency_seconds_bucket[10m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(sre_agent_hil_approval_latency_seconds_bucket[10m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "table",
      "title": "Scrape target status",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "up", "format": "table", "instant": true, "refId": "A" }
      ],
      "options": { "showHeader": true },
      "fieldConfig": {
        "defaults": {
          "custom": { "displayMode": "auto" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    }
  ],
